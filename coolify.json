{
  "port": 3010,
  "healthCheck": {
    "enabled": true,
    "path": "/health",
    "port": 3010,
    "interval": 30,
    "timeout": 5,
    "retries": 3
  },
  "build": {
    "command": "pnpm install && pnpm build"
  },
  "start": {
    "command": "pnpm start"
  },
  "environment": {
    "NODE_ENV": "production",
    "PORT": "3010"
  }
}
